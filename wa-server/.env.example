PORT=3000
NODE_ENV=development
# Samakan dengan WHATSAPP_SERVER_SECRET di Laravel .env — WAJIB jika NODE_ENV=production
WHATSAPP_SERVER_SECRET=
# 127.0.0.1 = hanya mesin lokal (disarankan). 0.0.0.0 = semua interface — hanya dengan secret kuat + firewall
WA_BIND=127.0.0.1
# Opsional — paksa Chrome sistem jika npm run setup tidak dipakai (contoh Kali):
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
