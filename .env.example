APP_NAME="Mall Store"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_store_topup
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ──────────────────────────────────────────
# Redis (opsional di lokal, sangat disarankan di production)
# ──────────────────────────────────────────
# Redis = penyimpanan key-value di memori, sangat cepat. Di Laravel dipakai untuk:
#   • Cache (mis. daftar channel Tripay, pengaturan site di HandleInertiaRequests)
#   • Antrian job (email tertunda, pengiriman WA, dsb. — tanpa membebani tabel `jobs` MySQL)
#   • Session admin/guest (mengurangi write ke MySQL)
#
# Tanpa Redis: CACHE_STORE=database + QUEUE_CONNECTION=database + SESSION_DRIVER=database sudah cukup.
# Dengan Redis: ganti ke redis seperti di blok PRODUCTION OVERRIDES.
#
# Client: `phpredis` (ekstensi PHP, lebih cepat) atau `predis` (murni PHP, paket sudah ada di composer).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Logical database index (0–15 default). Pisahkan agar key cache/session/queue tidak tercampur.
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
# Saat SESSION_DRIVER=redis, harus sama dengan nama koneksi di config/database.php:
# SESSION_CONNECTION=session

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@store.local"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────
# Payment Gateway
# Driver: midtrans (default) | tripay | mock
# Tanpa MIDTRANS_SERVER_KEY → otomatis mock (lokal).
# ──────────────────────────────────────────
PAYMENT_GATEWAY=midtrans

# Midtrans — uji transaksi di SANDBOX dulu:
# Dashboard sandbox: https://dashboard.sandbox.midtrans.com → Settings → Access Keys
# Kunci sandbox: SB-Mid-server-... dan SB-Mid-client-...
# MIDTRANS_IS_PRODUCTION=false → API + Snap sandbox (https://app.sandbox.midtrans.com)
# Notification URL di dashboard: {APP_URL}/webhooks/payment (HTTPS publik; lokal pakai ngrok/tunnel)
# Kartu uji: https://docs.midtrans.com/docs/testing-payment-on-sandbox
#
# MIDTRANS_ALLOW_PRODUCTION_IN_LOCAL=false — blokir production Midtrans saat APP_ENV=local (aman default).
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_ALLOW_PRODUCTION_IN_LOCAL=false

# Tripay — hanya jika PAYMENT_GATEWAY=tripay
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_MODE=sandbox

# ──────────────────────────────────────────
# WhatsApp — gateway Node (folder wa-server/, scan QR di Admin → WhatsApp)
# ──────────────────────────────────────────
# Di wa-server: npm install lalu npm run setup (unduh Chrome Puppeteer) lalu npm start
# URL yang bisa dijangkau dari PHP (satu mesin: http://127.0.0.1:3000)
# Production: HTTP hanya diizinkan ke localhost / IP privat; host publik → pakai HTTPS ke gateway Anda.
# WHATSAPP_SERVER_SECRET wajib di production (Laravel & wa-server NODE_ENV=production).
WA_SERVER_URL=http://127.0.0.1:3000
# Samakan dengan WHATSAPP_SERVER_SECRET di wa-server/.env — wajib di production
WHATSAPP_SERVER_SECRET=

# Nomor admin untuk ringkasan order (fallback jika Pengaturan Situs → WhatsApp kosong)
# Format: 628xxxxxxxxxx
WA_ADMIN_NUMBER=

# ──────────────────────────────────────────
# Notifikasi Email
# false = email dinonaktifkan, notifikasi hanya via WhatsApp
# Aktifkan dengan EMAIL_NOTIFICATIONS_ENABLED=true + konfigurasi MAIL_* yang valid
# ──────────────────────────────────────────
EMAIL_NOTIFICATIONS_ENABLED=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ══════════════════════════════════════════
# PRODUCTION OVERRIDES — uncomment saat deploy ke server live:
# ══════════════════════════════════════════
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://yourdomain.com
#
# LOG_LEVEL=error
#
# SESSION_ENCRYPT=true
# SESSION_DOMAIN=yourdomain.com
#
# TRIPAY_MODE=production
#
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# SESSION_CONNECTION=session

# Pilih driver pak_kasir
PAYMENT_GATEWAY=pak_kasir

# Masukkan data dari dashboard Pak Kasir
PAK_KASIR_API_KEY=isi_dengan_api_key_anda
PAK_KASIR_SLUG=isi_dengan_slug_proyek_anda

# Set ke 'sandbox' untuk tes atau 'production' jika sudah siap jualan
PAK_KASIR_MODE=sandbox

